<Window x:Class="Sentinel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Sentinel.Models"
        Title="Sentinel" Height="720" Width="1220"
        MinHeight="620" MinWidth="980"
        FontFamily="Segoe UI" Background="#101216"
        Icon="Assets/Sentinel.ico"
        WindowStyle="None" AllowsTransparency="True"
        StateChanged="Window_StateChanged">

    <Border x:Name="RootBorder" BorderBrush="#2A3342" BorderThickness="1" Background="#101216">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="34"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0D1016" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="Assets/SentinelMark.png" Width="18" Height="18" Stretch="Uniform" Margin="0,0,7,0"/>
                        <TextBlock Text="Sentinel" Foreground="#777777" FontSize="12" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                        <Button Content="-" Width="30" Height="24" Margin="2,0" Click="Minimize_Click"
                                Style="{StaticResource GhostBtn}" Padding="0" FontSize="12"/>
                        <Button Width="34" Height="24" Margin="2,0" Click="Maximize_Click"
                                Style="{StaticResource GhostBtn}" Padding="0">
                            <Border Width="10" Height="10" BorderBrush="#888888" BorderThickness="1" CornerRadius="1"/>
                        </Button>
                        <Button Content="X" Width="30" Height="24" Margin="2,0" Click="CloseToTray_Click"
                                Style="{StaticResource DangerBtn}" Padding="0" FontSize="11"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="224"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#0D1016">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Bottom" Content="Quit Sentinel"
                                Style="{StaticResource NavButton}" Margin="8,8" Click="Quit_Click"/>

                        <StackPanel Margin="14,28,14,0">
                            <Border CornerRadius="8" Background="#12161D" BorderBrush="#202632" BorderThickness="1"
                                    Padding="8" Margin="4,0,4,30">
                                <StackPanel>
                                    <Image Source="Assets/SentinelWordmark.png" Width="174" Height="62"
                                           Stretch="Uniform" HorizontalAlignment="Left"/>
                                    <TextBlock Text="Local security triage" Foreground="#777777" FontSize="11"
                                               Margin="8,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <Button x:Name="BtnDashboard" Content="Dashboard" Style="{StaticResource NavButton}" Click="Dashboard_Click"/>
                            <Button x:Name="BtnDownloads" Content="Downloads" Style="{StaticResource NavButton}" Click="Downloads_Click"/>
                            <Button x:Name="BtnFileAnalyzer" Content="File Analyzer" Style="{StaticResource NavButton}" Click="FileAnalyzer_Click"/>
                            <Button x:Name="BtnActivity" Content="Activity Monitor" Style="{StaticResource NavButton}" Click="Activity_Click"/>
                            <Button x:Name="BtnReports" Content="Reports" Style="{StaticResource NavButton}" Click="Reports_Click"/>
                            <Rectangle Height="1" Fill="#222222" Margin="8,12"/>
                            <Button x:Name="BtnSettings" Content="Settings" Style="{StaticResource NavButton}" Click="Settings_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#11141B" Offset="0"/>
                            <GradientStop Color="#12161D" Offset="0.6"/>
                            <GradientStop Color="#0F1218" Offset="1"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <Grid x:Name="DashboardView" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid Margin="40,38,40,34">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="360"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <Image Source="Assets/SentinelWordmark.png" Width="360" Height="120"
                                           Stretch="Uniform" HorizontalAlignment="Left" Margin="-8,-24,0,8"/>
                                    <TextBlock Text="Good afternoon" x:Name="GreetingText" FontSize="30"
                                               FontWeight="SemiBold" Foreground="#E8E8E8" Margin="0,0,0,6"/>
                                    <TextBlock Text="Sentinel watches Downloads locally and explains suspicious activity in plain English."
                                               Foreground="#777777" FontSize="13" Margin="0,0,0,28"/>

                                    <WrapPanel>
                                        <Border Width="190" Height="116" CornerRadius="8" Background="#171B23"
                                                Margin="0,0,16,16" BorderBrush="#2A3342" BorderThickness="1">
                                            <StackPanel Margin="20,16">
                                                <TextBlock x:Name="DownloadsCountText" Text="0" FontSize="34"
                                                           FontWeight="Bold" Foreground="#E8E8E8"/>
                                                <TextBlock Text="Downloads analyzed" FontSize="12" Foreground="#777777"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Width="190" Height="116" CornerRadius="8" Background="#171B23"
                                                Margin="0,0,16,16" BorderBrush="#2A3342" BorderThickness="1">
                                            <StackPanel Margin="20,16">
                                                <TextBlock x:Name="SuspiciousCountText" Text="0" FontSize="34"
                                                           FontWeight="Bold" Foreground="#E8E8E8"/>
                                                <TextBlock Text="Suspicious downloads" FontSize="12" Foreground="#777777"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Width="190" Height="116" CornerRadius="8" Background="#171B23"
                                                Margin="0,0,16,16" BorderBrush="#2A3342" BorderThickness="1">
                                            <StackPanel Margin="20,16">
                                                <TextBlock x:Name="ActivityCountText" Text="0" FontSize="34"
                                                           FontWeight="Bold" Foreground="#E8E8E8"/>
                                                <TextBlock Text="LOLBin alerts" FontSize="12" Foreground="#777777"/>
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Text="RECENT FINDINGS" FontSize="10" Foreground="#444444" Margin="0,28,0,12"/>
                                    <Border CornerRadius="8" Background="#171B23" BorderBrush="#2A3342"
                                            BorderThickness="1" Padding="18" HorizontalAlignment="Stretch">
                                        <StackPanel>
                                            <TextBlock x:Name="RecentDownloadText" Text="No downloads analyzed yet."
                                                       Foreground="#BBBBBB" FontSize="13" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="HighestRiskText" Text="Highest counted risk: 0/100"
                                                       Foreground="#777777" FontSize="12" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Border Grid.Column="1" CornerRadius="8" Background="#171B23"
                                        BorderBrush="#2A3342" BorderThickness="1" Padding="20" Margin="20,0,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Security Status" FontSize="16" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                        <TextBlock x:Name="StatusText" Text="Safe" FontSize="24" FontWeight="Bold"
                                                   Foreground="#22C55E" Margin="0,18,0,4"/>
                                        <TextBlock x:Name="StatusExplanationText"
                                                   Text="Sentinel is monitoring Downloads in the background."
                                                   TextWrapping="Wrap" Foreground="#BBBBBB"/>
                                        <Border BorderBrush="#7C3AED" BorderThickness="2,0,0,0" Padding="12,0,0,0" Margin="0,28,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Background Monitor" FontSize="13" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                                <TextBlock x:Name="MonitorStateText" Text="Running in tray" FontSize="12"
                                                           Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,24,0,0" Padding="0,18,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Ignored Safe Items" FontSize="13" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                                <TextBlock x:Name="SafeOverrideText" Text="No user-safe overrides yet."
                                                           FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,18,0,0" Padding="0,18,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Activity Signals" FontSize="13" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                                <TextBlock x:Name="ActivitySummaryText" Text="No LOLBin alerts stored."
                                                           FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border BorderBrush="#333333" BorderThickness="0,1,0,0" Margin="0,18,0,0" Padding="0,18,0,0">
                                            <StackPanel>
                                                <TextBlock Text="Local Data" FontSize="13" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                                <TextBlock x:Name="LocalDataText" Text="Reports and history stay on this PC."
                                                           FontSize="12" Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </ScrollViewer>
                    </Grid>

                    <Grid x:Name="DownloadsView" Visibility="Collapsed" Margin="40,34,40,34">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Download Inspector" FontSize="18" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                <TextBlock Text="Review suspicious filenames, scripts, executables, archives, and user-safe overrides."
                                           FontSize="12" Foreground="#777777" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button x:Name="MonitorToggleButton" Content="Start Monitor" Style="{StaticResource ToolbarBtn}" Click="StartMonitor_Click"/>
                                <Button Content="Scan Existing" Style="{StaticResource GhostBtn}" Margin="8,0,0,0" Click="ScanDownloads_Click"/>
                                <Button Content="Refresh" Style="{StaticResource GhostBtn}" Margin="8,0,0,0" Click="RefreshDownloads_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="1" Height="1" Background="#222222" Margin="0,12,0,18"/>

                        <Grid Grid.Row="2" Margin="0,0,10,9">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="FILE" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="1" Text="TYPE" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="2" Text="SEVERITY" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="3" Text="SCORE" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="4" Text="EXPLANATION" Style="{StaticResource ColumnHeaderText}"/>
                        </Grid>

                        <Border Grid.Row="3" CornerRadius="8" BorderBrush="#2A3342" BorderThickness="1"
                                Background="#12161D" Padding="10,6,4,6" ClipToBounds="True">
                            <ListView x:Name="DownloadsList" Background="Transparent" BorderThickness="0"
                                      Foreground="#CCCCCC" ItemContainerStyle="{StaticResource ListItemStyle}"
                                      SelectionMode="Single"
                                      PreviewMouseRightButtonDown="DownloadsList_RightClick"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Mark selected download safe" Click="MarkSafe_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:DownloadFinding}">
                                        <Grid Margin="0,0,8,0" ClipToBounds="True">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="280"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding FileName}" Foreground="#CCCCCC" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Category}" Foreground="#999999" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Severity}" Foreground="{Binding SeverityBrush}" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding DisplayScore}" Foreground="#999999" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding Explanation}" Foreground="#BBBBBB" Style="{StaticResource CellText}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>

                    <Grid x:Name="ActivityView" Visibility="Collapsed" Margin="40,38,40,34">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,28">
                            <StackPanel>
                                <TextBlock Text="Activity Monitor" FontSize="18" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                <TextBlock Text="Inspect live LOLBin command lines without terminating processes."
                                           FontSize="12" Foreground="#777777" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button Content="Scan Processes" Style="{StaticResource ToolbarBtn}" Click="ScanActivity_Click"/>
                                <Button Content="Copy Encoded" Style="{StaticResource GhostBtn}" Margin="8,0,0,0" Click="CopyEncoded_Click"/>
                            </StackPanel>
                        </DockPanel>
                        <Grid Grid.Row="1" Margin="0,0,10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="PROCESS" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="1" Text="PID" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="2" Text="SEVERITY" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="3" Text="RULE" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="4" Text="ENCODED COMMAND" Style="{StaticResource ColumnHeaderText}"/>
                            <TextBlock Grid.Column="5" Text="REASON" Style="{StaticResource ColumnHeaderText}"/>
                        </Grid>
                        <Border Grid.Row="2" CornerRadius="8" BorderBrush="#2A3342" BorderThickness="1"
                                Background="#12161D" Padding="10,6,4,6" ClipToBounds="True">
                            <ListView x:Name="ActivityList" Background="Transparent" BorderThickness="0"
                                      ItemContainerStyle="{StaticResource ListItemStyle}" SelectionMode="Single"
                                      PreviewMouseRightButtonDown="ActivityList_RightClick"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Mark selected activity safe" Click="MarkActivitySafe_Click"/>
                                        <MenuItem Header="Copy encoded PowerShell command" Click="CopyEncoded_Click"/>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:LolbinAlert}">
                                        <Grid Margin="0,0,8,0" ClipToBounds="True">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="170"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ProcessName}" Foreground="#CCCCCC" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Pid}" Foreground="#999999" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Severity}" Foreground="{Binding SeverityBrush}" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="3" Text="{Binding MatchedRule}" Foreground="#BBBBBB" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="4" Text="{Binding EncodedCommand}" Foreground="#BBBBBB" Style="{StaticResource CellText}"/>
                                            <TextBlock Grid.Column="5" Text="{Binding Reason}" Foreground="#BBBBBB" Style="{StaticResource CellText}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </Grid>

                    <Grid x:Name="FileAnalyzerView" Visibility="Collapsed" Margin="40,38,40,34">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,28">
                            <StackPanel>
                                <TextBlock Text="File Analyzer" FontSize="18" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                <TextBlock Text="Static local file inspection. Sentinel never executes selected files."
                                           FontSize="12" Foreground="#777777" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button Content="Analyze File" Style="{StaticResource ToolbarBtn}" Click="AnalyzeFile_Click"/>
                                <Button Content="Open YARA Folder" Style="{StaticResource GhostBtn}" Margin="8,0,0,0" Click="OpenYaraFolder_Click"/>
                            </StackPanel>
                        </DockPanel>
                        <Border Grid.Row="1" CornerRadius="8" BorderBrush="#2A3342" BorderThickness="1" Background="#171B23">
                            <TextBox x:Name="AnalyzerOutput" Background="Transparent" BorderThickness="0" Foreground="#BBBBBB"
                                     IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     FontFamily="Consolas" Padding="16"
                                     Text="Select a file to inspect hashes, file type risk, and static metadata. Files are never executed.">
                                <TextBox.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Mark analyzed file safe" Click="MarkAnalyzedFileSafe_Click"/>
                                    </ContextMenu>
                                </TextBox.ContextMenu>
                            </TextBox>
                        </Border>
                    </Grid>

                    <Grid x:Name="ReportsView" Visibility="Collapsed" Margin="40,38,40,34">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="0,0,0,28">
                            <StackPanel>
                                <TextBlock Text="Reports" FontSize="18" FontWeight="SemiBold" Foreground="#E8E8E8"/>
                                <TextBlock Text="Export local findings for helpdesk review, learning notes, or incident handoff."
                                           FontSize="12" Foreground="#777777" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                <Button Content="Export JSON" Style="{StaticResource ToolbarBtn}" Click="ExportJson_Click"/>
                                <Button Content="Export HTML" Style="{StaticResource GhostBtn}" Margin="8,0,0,0" Click="ExportHtml_Click"/>
                            </StackPanel>
                        </DockPanel>

                        <Border Grid.Row="1" CornerRadius="8" Background="#171B23" BorderBrush="#2A3342"
                                BorderThickness="1" Padding="18" VerticalAlignment="Top">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="32" Height="32" CornerRadius="8" Background="#202632"
                                        BorderBrush="#2A3342" BorderThickness="1" VerticalAlignment="Top">
                                    <Viewbox Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Canvas Width="24" Height="24">
                                            <Path Stroke="#7C3AED" StrokeThickness="1.8" StrokeLineJoin="Round"
                                                  Fill="Transparent" Data="M6,3 L15,3 L20,8 L20,21 L6,21 Z"/>
                                            <Path Stroke="#7C3AED" StrokeThickness="1.8" StrokeLineJoin="Round"
                                                  Fill="Transparent" Data="M15,3 L15,8 L20,8"/>
                                            <Path Stroke="#7C3AED" StrokeThickness="1.8" StrokeStartLineCap="Round"
                                                  Data="M9,12 L17,12"/>
                                            <Path Stroke="#7C3AED" StrokeThickness="1.8" StrokeStartLineCap="Round"
                                                  Data="M9,16 L15,16"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Report output" Foreground="#E8E8E8" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ReportOutput" Text="No report exported in this session."
                                               Foreground="#BBBBBB" FontSize="13" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid x:Name="SettingsView" Visibility="Collapsed" Margin="40,38,40,34">
                        <StackPanel Width="760" HorizontalAlignment="Left">
                            <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Foreground="#E8E8E8" Margin="0,0,0,6"/>
                            <TextBlock Text="Local paths and background behavior." FontSize="12" Foreground="#777777" Margin="0,0,0,28"/>
                            <Border CornerRadius="8" Background="#171B23" BorderBrush="#2A3342" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="DOWNLOADS FOLDER" Style="{StaticResource ColumnHeaderText}" Margin="0,0,0,8"/>
                                    <TextBox x:Name="DownloadsPathText" Style="{StaticResource DarkInput}" Height="36"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="#171B23" BorderBrush="#2A3342" BorderThickness="1"
                                    Padding="16" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="YARA RULES FOLDER" Style="{StaticResource ColumnHeaderText}" Margin="0,0,0,8"/>
                                    <TextBox x:Name="YaraPathText" Style="{StaticResource DarkInput}" Height="36"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="#171B23" BorderBrush="#2A3342" BorderThickness="1"
                                    Padding="16,14" Margin="0,0,0,14">
                                <StackPanel>
                                    <CheckBox x:Name="AutoMonitorCheck" Content="Start monitoring automatically"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Keeps the Downloads monitor running while Sentinel is open or hidden in the tray."
                                               Foreground="#777777" FontSize="12" TextWrapping="Wrap" Margin="28,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="#171B23" BorderBrush="#2A3342" BorderThickness="1"
                                    Padding="16,14" Margin="0,0,0,14">
                                <StackPanel>
                                    <CheckBox x:Name="CloseToTrayCheck" Content="Close button hides Sentinel to the tray"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="When disabled, the X button exits the app instead of leaving the monitor running."
                                               Foreground="#777777" FontSize="12" TextWrapping="Wrap" Margin="28,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="8" Background="#171B23" BorderBrush="#2A3342" BorderThickness="1"
                                    Padding="16,14" Margin="0,0,0,20">
                                <StackPanel>
                                    <CheckBox x:Name="OpenOnStartupCheck" Content="Start Sentinel when Windows starts"
                                              VerticalAlignment="Center"/>
                                    <CheckBox x:Name="OpenToTrayStartupCheck" Content="Open to tray on startup instead of showing the window"
                                              VerticalAlignment="Center" Margin="0,10,0,0"/>
                                    <TextBlock Text="Turn off the tray option if you want the full Sentinel window to open after signing in."
                                               Foreground="#777777" FontSize="12" TextWrapping="Wrap" Margin="28,6,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button Content="Save Settings" Style="{StaticResource ToolbarBtn}" Width="120" HorizontalAlignment="Left" Click="SaveSettings_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
            <Border Grid.Row="2" Background="#0D1016" BorderBrush="#202632" BorderThickness="0,1,0,0">
                <DockPanel Margin="18,0">
                    <TextBlock Text="Sentinel" Foreground="#333333" FontSize="10"
                               VerticalAlignment="Center" DockPanel.Dock="Right"/>
                    <TextBlock x:Name="ActionStatusText" Text="Ready" Foreground="#777777" FontSize="12"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>

