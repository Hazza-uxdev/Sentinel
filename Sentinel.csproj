<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>Assets\Sentinel.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="Assets\Sentinel.ico" CopyToOutputDirectory="PreserveNewest" />
    <Resource Include="Assets\SentinelMark.png" />
    <Resource Include="Assets\SentinelWordmark.png" />
  </ItemGroup>

  <ItemGroup>
    <ApplicationDefinition Remove="GitHubSource\App.xaml" />
    <Compile Remove="GitHubSource\**\*.cs" />
    <Page Remove="GitHubSource\**\*.xaml" />
    <Resource Remove="GitHubSource\**\*" />
    <Content Remove="GitHubSource\**\*" />
    <None Remove="GitHubSource\**\*" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Management" Version="8.0.0" />
  </ItemGroup>
</Project>
